{
  "name": "birdplan-api",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "type": "module",
  "main": "server.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "dev:fastify": "fastify start -w -l info -P dist/app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^8.0.0",
    "@fastify/env": "^5.0.0",
    "@fastify/sensible": "^6.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "fastify-cli": "^7.4.0",
    "firebase-admin": "^11.0.0",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "@fastify/type-provider-json-schema-to-ts": "^2.2.2",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.10.0",
    "pino-pretty": "^10.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
